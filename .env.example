# ============================================================
# BGS Alumni Management System — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# --- Gmail / Google OAuth2 (for Gmail API — optional) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-render-domain.onrender.com/api/gmail/callback
GOOGLE_REFRESH_TOKEN=

# --- Gmail SMTP (App Password — simpler alternative) ---
GMAIL_USER=your-gmail-account@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# --- Session Security ---
# Generate a strong random string (min 32 characters).
# Example: openssl rand -hex 32
SESSION_SECRET=replace-with-a-secure-random-string-of-at-least-32-characters

# --- CORS Origins ---
# Comma-separated list of frontend origins allowed to make credentialed API requests.
ALLOWED_ORIGINS=http://localhost:5173,https://your-cloudflare-pages-domain.pages.dev

# --- Server Port (optional, defaults to 5000) ---
PORT=5000
